# Vercel Environment Configuration Example
# Copy this to Vercel Dashboard under "Environment Variables"

# API Configuration
VITE_API_BASE_URL=https://your-backend-api.vercel.app

# App Configuration
VITE_APP_NAME=Panel Pulse AI
VITE_ENABLE_MOCK=false

# Note: Replace 'https://your-backend-api.vercel.app' with:
# - For local testing: http://localhost:3000
# - For VM deployment: http://10.10.142.91
# - For production backend: https://your-production-api.com
